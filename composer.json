{
    "name": "wallacemartinss/filament-security",
    "description": "Security plugin for Filament v5 - Disposable email blocking, honeypot protection, and Cloudflare IP blocking",
    "keywords": [
        "laravel",
        "filament",
        "security",
        "honeypot",
        "disposable-email",
        "cloudflare",
        "ip-blocking",
        "bot-protection"
    ],
    "homepage": "https://github.com/wallacemartinss/filament-security",
    "license": "MIT",
    "authors": [
        {
            "name": "Wallace Martins",
            "email": "wallacemartinss@gmail.com",
            "role": "Developer"
        }
    ],
    "require": {
        "php": "^8.2",
        "filament/filament": "^5.0",
        "spatie/laravel-honeypot": "^4.0",
        "spatie/laravel-package-tools": "^1.16"
    },
    "require-dev": {
        "laravel/pint": "^1.0",
        "nunomaduro/collision": "^8.0",
        "orchestra/testbench": "^9.0|^10.0|^11.0",
        "phpunit/phpunit": "^11.0"
    },
    "autoload": {
        "psr-4": {
            "WallaceMartinss\\FilamentSecurity\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "WallaceMartinss\\FilamentSecurity\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "analyse": "vendor/bin/phpstan analyse",
        "test": "vendor/bin/phpunit",
        "format": "vendor/bin/pint"
    },
    "config": {
        "sort-packages": true
    },
    "extra": {
        "laravel": {
            "providers": [
                "WallaceMartinss\\FilamentSecurity\\FilamentSecurityServiceProvider"
            ]
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
